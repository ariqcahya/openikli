{
  "name": "opensource-ikli-root",
  "version": "1.0.0",
  "private": true,
  "description": "OpenSource-IKLI Monorepo Root",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter database db:migrate",
    "db:seed": "pnpm --filter database db:seed",
    "db:generate": "pnpm --filter database db:generate",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,css}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
